    {
      "name": "12 - Get Notifications (User B)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Dev-User-Id",
            "value": "{{userBId}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notifications?filter=all&limit=50&offset=0",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notifications"
          ],
          "query": [
            {
              "key": "filter",
              "value": "all"
            },
            {
              "key": "limit",
              "value": "50"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        },
        "description": "Expected to include follow, like, comment, and system(chat) notifications for user B."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const j = pm.response.json();",
              "pm.test('Has notifications array', function () {",
              "  pm.expect(Array.isArray(j.notifications)).to.eql(true);",
              "});",
              "const unread = (j.notifications || []).find((n) => n && n.is_read === false);",
              "if (unread && unread.id) pm.environment.set('notificationId', unread.id);"
            ]
          }
        }
      ]
    },
