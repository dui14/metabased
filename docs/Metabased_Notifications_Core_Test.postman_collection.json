{
  "info": {
    "name": "Metabased Notifications Core Test",
    "description": "Test flow for 4 notification types only: follow, like, comment, and chat(system). If you see NEXT_NOT_FOUND HTML, check baseUrl port and call APIs in Postman/cURL instead of in-app client navigation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "00 - Create User A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"wallet_address\": \"{{walletA}}\",\n  \"email\": \"{{emailA}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "profile"
          ]
        },
        "description": "Create or detect User A"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 or 409', function () {",
              "  pm.expect([201, 409]).to.include(pm.response.code);",
              "});",
              "const j = pm.response.json();",
              "if (j.user && j.user.id) pm.environment.set('userAId', j.user.id);"
            ]
          }
        }
      ]
    },
